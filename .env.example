# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# Massive / Polygon.io — daily price data
# Get a free key at: https://massive.io  or  https://polygon.io
MASSIVE_API_KEY=your_massive_api_key_here

# FRED — macro data (free, takes ~60 seconds to register)
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# WRDS — CRSP / Compustat / IBES (institutional subscription required)
# https://wrds-www.wharton.upenn.edu/
WRDS_USERNAME=your_wrds_username_here

# Optional: dashboard port (default 8080)
# PORT=8080

# Optional: host binding (default 0.0.0.0 for Docker, 127.0.0.1 for local)
# HOST=0.0.0.0
